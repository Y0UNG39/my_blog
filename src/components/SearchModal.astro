---
---

<div id="search-modal" class="hidden fixed inset-0 z-[100] bg-black/50 flex items-start justify-center pt-[15vh]">
  <div class="bg-white dark:bg-[var(--color-dark-bg-secondary)] rounded-xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
    <div class="flex items-center border-b border-[var(--color-border)] dark:border-[var(--color-dark-border)] px-4">
      <svg class="w-5 h-5 text-[var(--color-text-secondary)] dark:text-[var(--color-dark-text-secondary)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章..."
        class="flex-1 px-3 py-4 bg-transparent text-[var(--color-text)] dark:text-[var(--color-dark-text)] outline-none placeholder:text-[var(--color-text-secondary)] dark:placeholder:text-[var(--color-dark-text-secondary)]"
      />
      <kbd class="hidden sm:inline-block text-xs px-1.5 py-0.5 rounded border border-[var(--color-border)] dark:border-[var(--color-dark-border)] text-[var(--color-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">ESC</kbd>
    </div>
    <div id="search-results" class="max-h-80 overflow-y-auto p-2"></div>
    <div id="search-empty" class="hidden p-8 text-center text-sm text-[var(--color-text-secondary)] dark:text-[var(--color-dark-text-secondary)]">
      没有找到相关文章
    </div>
  </div>
</div>

<script is:inline>
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');
  const emptyMsg = document.getElementById('search-empty');
  let pagefind;

  async function initSearch() {
    if (!pagefind) {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    }
  }

  function openSearch() {
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    input.value = '';
    results.innerHTML = '';
    emptyMsg.classList.add('hidden');
    setTimeout(() => input.focus(), 50);
    initSearch();
  }

  function closeSearch() {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  document.getElementById('search-toggle')?.addEventListener('click', openSearch);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeSearch();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });

  input?.addEventListener('input', async (e) => {
    const query = e.target.value.trim();
    if (!query || !pagefind) {
      results.innerHTML = '';
      emptyMsg.classList.add('hidden');
      return;
    }
    const search = await pagefind.debouncedSearch(query);
    if (!search) return;
    const data = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
    if (data.length === 0) {
      results.innerHTML = '';
      emptyMsg.classList.remove('hidden');
      return;
    }
    emptyMsg.classList.add('hidden');
    results.innerHTML = data.map((item) => `
      <a href="${item.url}" class="block px-3 py-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-dark-bg)] transition-colors">
        <div class="font-medium text-sm text-[var(--color-text)] dark:text-[var(--color-dark-text)]">${item.meta.title || '无标题'}</div>
        <div class="text-xs text-[var(--color-text-secondary)] dark:text-[var(--color-dark-text-secondary)] mt-0.5 line-clamp-1">${item.excerpt || ''}</div>
      </a>
    `).join('');
  });
</script>
